from math import factorial

def phi(n):
    result = n
    p = 2
    m = n
    while p * p <= m:
        if m % p == 0:
            while m % p == 0:
                m //= p
            result -= result // p
        p += 1
    if m > 1:
        result -= result // m
    return result

LIMIT = 100000

facts = set()
f = 1
k = 1
while f <= LIMIT:
    facts.add(f)
    k += 1
    f *= k

for n in range(1, LIMIT + 1):
    if phi(n) in facts:
        print(n, phi(n))
