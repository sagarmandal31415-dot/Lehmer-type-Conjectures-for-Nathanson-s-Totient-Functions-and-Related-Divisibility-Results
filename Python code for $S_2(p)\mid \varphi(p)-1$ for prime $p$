def is_prime(n):
    if n < 2:
        return False
    if n % 2 == 0:
        return n == 2
    i = 3
    while i * i <= n:
        if n % i == 0:
            return False
        i += 2
    return True

def search(limit):
    for p in range(3, limit):
        if is_prime(p):
            if pow(2, p, p-2) == 3 % (p-2):
                print(p)

search(10000000)
